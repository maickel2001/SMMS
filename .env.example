# =====================================================
# CONFIGURATION PLATEFORME SMM
# =====================================================

# Base de données
DB_HOST=localhost
DB_NAME=smm_platform
DB_USER=your_db_username
DB_PASS=your_db_password

# Configuration SMTP (Sendinblue)
SMTP_HOST=smtp-relay.sendinblue.com
SMTP_PORT=587
SMTP_USERNAME=your_sendinblue_username
SMTP_PASSWORD=your_sendinblue_password
SMTP_FROM_EMAIL=noreply@votredomaine.com
SMTP_FROM_NAME=SMM Platform

# Configuration Mobile Money
MOMO_NUMBER=+2250700000000
MOMO_OPERATOR=MoMo

# Configuration du site
SITE_NAME=SMM Platform
SITE_URL=https://votredomaine.com
CURRENCY=FCFA

# Sécurité
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_here

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png
UPLOAD_PATH=uploads/payments/

# Configuration admin
ADMIN_EMAIL=admin@smmplatform.com
ADMIN_PASSWORD=admin123